{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "allowJs": true,
    "checkJs": false,
    "outDir": "build",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "envio-env.d.ts", ".envio/**/*.d.ts"],
  "exclude": ["node_modules", "build"]
}
